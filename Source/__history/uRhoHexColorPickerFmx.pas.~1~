procedure THexColorPicker.SelectCombIndex(i: integer);
var
 j: integer;
begin
 if i > 0 then
  begin
   if FColorCombs <> nil then
    for j := 0 to High(FColorCombs) do
     if FColorCombs[j].TabIndex = i then
      begin
       SetSelectedColor(FColorCombs[j].Color);
       Break;
      end;
  end
 else
  if FBWCombs <> nil then
   for j := 1 to High(FBWCombs) - 1 do
    if FBWCombs[j].TabIndex = i then
     begin
      SetSelectedColor(FBWCombs[j].Color);
      Break;
     end;
end;

function THexColorPicker.GetSelectedCombIndex: integer;
begin
 if FSelectedCombIndex < 0 then
  Result := FBWCombs[-FSelectedCombIndex].TabIndex
 else
  Result := FColorCombs[FSelectedCombIndex].TabIndex;
end;

function THexColorPicker.GetNextCombIndex(i: integer): integer;
begin
 if i = 127 then
  Result := -1
 else
  if i = -15 then
   Result := 1
  else
   if i > 0 then
    Result := i + 1
   else
    Result := i - 1;
end;

function THexColorPicker.GetPreviousCombIndex(i: integer): integer;
begin
 if i = 1 then
  Result := -15
 else
  if i = -1 then
   Result := 127
   else
    if i > 0 then
     Result := i - 1
    else
     Result := i + 1;
end;

//-- intensity & geometry setters ----------------------------------------------

function THexColorPicker.GetIntensity: integer;
begin
 Result := ROUND(FCenterIntensity * 100);
end;

procedure THexColorPicker.SetIntensity(v: integer);
var
 s: single;
begin
 s := v / 100;
 FCenterIntensity := s;
 if FCenterIntensity < 0 then FCenterIntensity := 0;
 if FCenterIntensity > 1 then FCenterIntensity := 1;
 FCenterColor.Red := DefCenterColor.Red * FCenterIntensity;
 FCenterColor.Green := DefCenterColor.Green * FCenterIntensity;
 FCenterColor.Blue := DefCenterColor.Blue * FCenterIntensity;
 FColorCombs := nil;
 CalculateCombLayout;
 EndSelection;
 Repaint;
 if Assigned(FOnIntensityChange) then
  FOnIntensityChange(Self);
end;

procedure THexColorPicker.ChangeIntensity(increase: boolean);
var
 i: integer;
begin
 i := ROUND(FCenterIntensity * 100);
 if increase then
  begin
   Inc(i, FIncrement);
   if i > 100 then i := 100;
  end
 else
  begin
   Dec(i, FIncrement);
   if i < 0 then i := 0;
  end;
 SetIntensity(i);
end;

procedure THexColorPicker.SetRadius(r: integer);
begin
 FRadius := r;
 DrawAll;
 CalculateCombLayout;
 Repaint;
end;

procedure THexColorPicker.SetSliderWidth(w: integer);
begin
 if (FSliderWidth <> w) and FSliderVisible then
  begin
   FSliderWidth := w;
   DrawAll;
   Width := FSliderRect.Right + 2;
   CalculateCombLayout;
   Repaint;
  end;
end;

procedure THexColorPicker.SetBackgroundColor(const Value: TAlphaColor);
begin
 if FBackgroundColor <> Value then
  begin
   FBackgroundColor := Value;
   Repaint;
  end;
end;

procedure THexColorPicker.Resize;
var
 rw, rh: integer;
begin
 inherited;
 if not FInitialized then
  Exit;
 if (Width >= 93) and (Height >= 85) then
  begin
   if FSliderVisible then
    rw := Round((Width - 10 - FSliderWidth) / 2)
   else
    rw := Round(Width / 2 - 5);
   // reserve vertical space for the opacity bar so it doesn't overlap the combs
   if FOpacityVisible then
    rh := Round((24 / 53) * (Height - 6 - OpacityStrip))
   else
    rh := Round((24 / 53) * (Height - 6));
   SetRadius(Min(rw, rh));
  end;
end;

function THexColorPicker.SelectAvailableColor(Color: TAlphaColor): boolean;
var
 I: integer;
 found: Boolean;
begin
 found := False;
 Result := false;
 if FColorCombs = nil then CalculateCombLayout;
 FCustomIndex := 0;
 FSelectedIndex := NoCell;
 for I := 0 to High(FBWCombs) do
  if SameRGB(FBWCombs[I].Color, Color) then
   begin
    FSelectedIndex := CustomCell;
    FCustomIndex := -(I + 1);
    found := True;
    Result := true;
    Break;
   end;
 if not found then
  for I := 0 to High(FColorCombs) do
   if SameRGB(FColorCombs[I].Color, Color) then
    begin
     FSelectedIndex := CustomCell;
     FCustomIndex := I + 1;
     Result := true;
     Break;
    end;
end;

procedure THexColorPicker.SelectColor(Color: TAlphaColor);
begin
 SelectAvailableColor(Color);
 Repaint;
 if Assigned(FOnChange) then
  FOnChange(Self);
end;

procedure THexColorPicker.SetSliderVisible(Value: boolean);
begin
 if FSliderVisible <> Value then
  begin
   FSliderVisible := Value;
   DrawAll;
   CalculateCombLayout;
   Repaint;
  end;
end;

procedure THexColorPicker.SetMarker(Value: TMarker);
begin
 if FMarker <> Value then
  begin
   FMarker := Value;
   DrawAll;
   CalculateCombLayout;
   Repaint;
  end;
end;

procedure THexColorPicker.SetNewArrowStyle(Value: boolean);
begin
 if FNewArrowStyle <> Value then
  begin
   FNewArrowStyle := Value;
   DrawAll;
   CalculateCombLayout;
   Repaint;
  end;
end;

